<UserControl x:Class="VHWuWa.App.Views.HomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,22,28,22">
            <TextBlock Text="VHWuWa" FontSize="28" FontWeight="Bold" />
            <TextBlock Text="Công cụ cài &amp; quản lý bản Việt hóa" Opacity="0.7" Margin="0,2,0,18" />

            <ui:Card Padding="18" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="Thông tin game" FontWeight="SemiBold" Margin="0,0,0,10" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Tên game:" Opacity="0.7" Margin="0,2" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding GameName}" Margin="12,2" />
                        <TextBlock Grid.Row="1" Text="Phiên bản game:" Opacity="0.7" Margin="0,2" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DetectedVersion}" Margin="12,2" />
                        <TextBlock Grid.Row="2" Text="Trạng thái Việt hóa:" Opacity="0.7" Margin="0,2" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding TranslationStatus}" Margin="12,2" />
                        <TextBlock Grid.Row="3" Text="Phiên bản Việt hóa:" Opacity="0.7" Margin="0,2" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding TranslationVersion}" Margin="12,2" />
                        <TextBlock Grid.Row="4" Text="Đường dẫn game:" Opacity="0.7" Margin="0,2" />
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding PathStatus}" Margin="12,2" />
                    </Grid>
                </StackPanel>
            </ui:Card>

            <ui:Card Padding="18" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="Thư mục game" FontWeight="SemiBold" Margin="0,0,0,10" />
                    <TextBox Text="{Binding GamePath}" IsReadOnly="True" Margin="0,0,0,10" />
                    <WrapPanel>
                        <Button Content="📁 Chọn thư mục" Command="{Binding ChooseFolderCommand}" Margin="0,0,8,8" />
                        <Button Content="🔍 Tự tìm game" Command="{Binding AutoDetectCommand}" Margin="0,0,8,8" />
                        <Button Content="📂 Mở thư mục" Command="{Binding OpenFolderCommand}" Margin="0,0,8,8" />
                        <Button Content="✔ Kiểm tra file" Command="{Binding CheckFilesCommand}" Margin="0,0,8,8" />
                    </WrapPanel>
                </StackPanel>
            </ui:Card>

            <WrapPanel Margin="0,0,0,10">
                <ui:Button Content="⬇ Cài Việt hóa" Appearance="Primary"
                        Command="{Binding InstallCommand}" IsEnabled="{Binding PathOk}"
                        MinWidth="150" Margin="0,0,10,10" />
                <Button Content="🗑 Gỡ Việt hóa" Command="{Binding UninstallCommand}"
                        MinWidth="150" Margin="0,0,10,10" />
            </WrapPanel>

            <ProgressBar IsIndeterminate="True" Height="4"
                         Visibility="{Binding Busy, Converter={StaticResource BoolToVis}}" Margin="0,4" />
            <TextBlock Text="{Binding Message}" TextWrapping="Wrap" Opacity="0.85" Margin="0,6,0,0" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
