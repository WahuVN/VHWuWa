<UserControl x:Class="VHWuWa.App.Views.FontPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="28,22,28,22">
        <TextBlock Text="Font chữ" FontSize="24" FontWeight="Bold" Margin="0,0,0,14" />
        <ui:Card Padding="18" Margin="0,0,0,14">
            <StackPanel>
                <TextBlock Text="Font đang dùng:" Opacity="0.7" />
                <TextBlock Text="{Binding CurrentFont}" FontWeight="SemiBold" FontSize="16" Margin="0,4,0,0" />
            </StackPanel>
        </ui:Card>
        <WrapPanel>
            <ui:Button Content="🔤 Áp dụng font (.vhwpack)" Appearance="Primary"
                    Command="{Binding ApplyCommand}" Margin="0,0,10,10" />
            <Button Content="↩ Khôi phục font mặc định" Command="{Binding RestoreCommand}" Margin="0,0,10,10" />
        </WrapPanel>
        <ProgressBar IsIndeterminate="True" Height="4"
                     Visibility="{Binding Busy, Converter={StaticResource BoolToVis}}" Margin="0,4" />
        <TextBlock Text="{Binding Message}" TextWrapping="Wrap" Opacity="0.85" Margin="0,6,0,0" />

        <TextBlock Text="Xem trước font" FontSize="18" FontWeight="Bold" Margin="0,22,0,10" />
        <ui:Card Padding="16">
            <StackPanel>
                <WrapPanel Margin="0,0,0,10">
                    <ui:Button Content="📂 Chọn font để xem trước" Appearance="Primary"
                            Command="{Binding PreviewFontCommand}" Margin="0,0,10,0" />
                </WrapPanel>
                <TextBlock Text="Chữ mẫu:" Opacity="0.7" Margin="0,0,0,4" />
                <ui:TextBox Text="{Binding SampleText, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="Nhập chữ mẫu để xem trước" Margin="0,0,0,10" />
                <Border Background="#151B29" CornerRadius="8" Padding="6" MinHeight="120">
                    <Image Source="{Binding PreviewImage}" Stretch="Uniform"
                           HorizontalAlignment="Left" />
                </Border>
                <TextBlock Text="{Binding PreviewMessage}" TextWrapping="Wrap"
                           Opacity="0.75" Margin="0,8,0,0" />
            </StackPanel>
        </ui:Card>
    </StackPanel>
    </ScrollViewer>
</UserControl>
