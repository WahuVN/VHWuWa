<UserControl x:Class="VHWuWa.App.Views.ModPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Grid Margin="28,22,28,22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Quản lý mod" FontSize="24" FontWeight="Bold" Margin="0,0,0,14" />
        <WrapPanel Grid.Row="1" Margin="0,0,0,10">
            <ui:Button Content="➕ Thêm mod" Appearance="Primary" Command="{Binding AddModCommand}" Margin="0,0,10,0" />
            <Button Content="🔁 Bật/Tắt" Command="{Binding ToggleCommand}" Margin="0,0,10,0" />
            <Button Content="🗑 Gỡ" Command="{Binding UninstallCommand}" Margin="0,0,10,0" />
            <Button Content="📂 Mở thư mục game" Command="{Binding OpenFolderCommand}" />
        </WrapPanel>
        <ui:Card Grid.Row="2" Padding="6">
            <ListView ItemsSource="{Binding Mods}" SelectedItem="{Binding SelectedMod}"
                      BorderThickness="0" Background="Transparent">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Tên" Width="220" DisplayMemberBinding="{Binding Name}" />
                        <GridViewColumn Header="Phiên bản" Width="90" DisplayMemberBinding="{Binding Version}" />
                        <GridViewColumn Header="Bật" Width="60" DisplayMemberBinding="{Binding Enabled}" />
                        <GridViewColumn Header="Dung lượng (KB)" Width="120" DisplayMemberBinding="{Binding SizeBytes}" />
                        <GridViewColumn Header="Xung đột" Width="200" DisplayMemberBinding="{Binding Conflicts.Count}" />
                    </GridView>
                </ListView.View>
            </ListView>
        </ui:Card>
        <TextBlock Grid.Row="3" Text="{Binding Message}" Opacity="0.85" Margin="0,10,0,0" TextWrapping="Wrap" />
    </Grid>
</UserControl>
