<UserControl x:Class="VHWuWa.App.Views.InstallPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Grid Margin="28,22,28,22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Cài Việt hóa" FontSize="24" FontWeight="Bold" Margin="0,0,0,14" />
        <WrapPanel Grid.Row="1" Margin="0,0,0,10">
            <Button Content="📦 Chọn gói .vhwpack" Command="{Binding PickPackageCommand}" Margin="0,0,10,0" />
            <ui:Button Content="⬇ Cài đặt" Appearance="Primary" Command="{Binding InstallCommand}" Margin="0,0,10,0" />
            <Button Content="✖ Hủy" Command="{Binding CancelCommand}"
                    Visibility="{Binding Busy, Converter={StaticResource BoolToVis}}" />
        </WrapPanel>
        <ui:Card Grid.Row="2" Padding="14" Margin="0,4,0,10">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="{Binding Summary}" TextWrapping="Wrap"
                           FontWeight="SemiBold" Margin="0,0,0,8" />
                <TextBlock DockPanel.Dock="Top" Text="Nội dung sẽ cài:" Opacity="0.7" Margin="0,0,0,6" />
                <ListBox ItemsSource="{Binding Files}" BorderThickness="0" Background="Transparent" />
            </DockPanel>
        </ui:Card>
        <StackPanel Grid.Row="3">
            <ProgressBar Value="{Binding Progress}" Maximum="100" Height="8" />
            <TextBlock Text="{Binding ProgressText}" Opacity="0.8" Margin="0,6,0,0" TextWrapping="Wrap" />
        </StackPanel>
    </Grid>
</UserControl>
