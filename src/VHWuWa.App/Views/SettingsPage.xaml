<UserControl x:Class="VHWuWa.App.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,22,28,22">
            <TextBlock Text="Cài đặt" FontSize="24" FontWeight="Bold" Margin="0,0,0,14" />

            <ui:Card Padding="18" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="Thư mục game" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBox Text="{Binding GamePath}" IsReadOnly="True" Margin="0,0,0,8" />
                    <Button Content="📁 Chọn thư mục" Command="{Binding ChooseFolderCommand}" HorizontalAlignment="Left" />
                </StackPanel>
            </ui:Card>

            <ui:Card Padding="18" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="Giao diện" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <CheckBox Content="Chế độ tối" IsChecked="{Binding IsDark}" Margin="0,0,0,6" />
                    <CheckBox Content="Tự động kiểm tra cập nhật khi mở app" IsChecked="{Binding AutoCheckUpdate}" />
                </StackPanel>
            </ui:Card>

            <ui:Card Padding="18" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="Cập nhật ứng dụng" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBlock Text="{Binding AppVersion}" Opacity="0.75" Margin="0,0,0,8" />
                    <ui:Button Content="🔄 Kiểm tra cập nhật" Appearance="Primary"
                            Command="{Binding CheckUpdateCommand}" HorizontalAlignment="Left" />
                    <TextBlock Text="{Binding UpdateMessage}" TextWrapping="Wrap" Opacity="0.85" Margin="0,8,0,0" />
                </StackPanel>
            </ui:Card>

            <Button Content="📝 Mở thư mục Nhật ký" Command="{Binding OpenLogFolderCommand}" HorizontalAlignment="Left" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
